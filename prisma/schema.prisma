generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  name             String          @unique
  password         String          @default("")
  role             String          @default("USER") // "USER" or "ADMIN"
  showInHighscore  Boolean         @default(true)
  email            String?
  emailPref        String          @default("NONE") // "ALL", "NONE", "SPECIFIC"
  entries          TimeEntry[]
  tasksCreated     Task[]          @relation("UserTasksCreated")
  taskVolunteering TaskVolunteer[]
  taskDateVotes    TaskDateVote[]
  taskNotes        TaskNote[]
  subscribedTasks  Task[]          @relation("TaskSubscribers")
  newsPosts        NewsPost[]      @relation("UserNewsPosts")
  pollVotes        PollVote[]
  createdAt        DateTime        @default(now())
}

model TimeEntry {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  startTime     DateTime
  endTime       DateTime?
  activity      String?   // User-selected activity grouping
  isConfirmed   Boolean   @default(false)
  isManualEntry Boolean   @default(false)
  isSubmitted   Boolean   @default(false)
  isArchived    Boolean   @default(false)
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Task {
  id              String          @id @default(uuid())
  title           String
  description     String?
  creatorId       String
  creator         User            @relation("UserTasksCreated", fields: [creatorId], references: [id])
  creatorName     String      
  imageUrl        String?         // Link zu einem Bild
  dueDate         DateTime?       // Feststehendes Termin-Datum (sobald Terminiert)
  status          String          @default("OPEN") // "OPEN", "IN_PROGRESS", "DONE", "SCHEDULED"
  estimatedHours  Int?
  creatorIsContact Boolean        @default(true) // Ersteller als Zuständig?
  materials       TaskMaterial[]
  steps           TaskStep[]
  volunteers      TaskVolunteer[]
  dateProposals   TaskDateProposal[]
  notes           TaskNote[]
  videos          TaskVideo[]
  subscribers     User[]          @relation("TaskSubscribers")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model TaskStep {
  id            String    @id @default(uuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  description   String
  estimatedHours Int?
  isCompleted   Boolean   @default(false)
}

model TaskMaterial {
  id            String    @id @default(uuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name          String
  buyLink       String?
  isAcquired    Boolean   @default(false)
}

model TaskVolunteer {
  id            String    @id @default(uuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName      String
  role          String    @default("HELPER") // "CONTACT" (Ansprechpartner) or "HELPER"
}

model TaskDateProposal {
  id            String    @id @default(uuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  date          DateTime
  timeOfDay     String    @default("ALL_DAY") // "MORNING", "AFTERNOON", "EVENING", "ALL_DAY" - deprecated
  startTime     String    @default("08:00")
  endTime       String    @default("12:00")
  votes         TaskDateVote[]
  createdAt     DateTime  @default(now())
}

model TaskDateVote {
  id            String    @id @default(uuid())
  proposalId    String
  proposal      TaskDateProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName      String
  vote          String    // "YES", "NO", "MAYBE"
  createdAt     DateTime  @default(now())
  
  @@unique([proposalId, userId])
}

model TaskNote {
  id            String    @id @default(uuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName      String
  content       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([taskId, userId])
}

model TaskVideo {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url         String
  description String?
}

model FundingStatus {
  id                String    @id @default("singleton")
  totalAmount       Float     @default(125409.53)
  disbursedAmount   Float     @default(14643.72)
  submittedAmount   Float     @default(13558.31)
  lastSubmittedDate DateTime?
}

model NewsPost {
  id        String   @id @default(uuid())
  title     String
  content   String
  imageUrl  String?
  authorId  String
  author    User     @relation("UserNewsPosts", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Poll {
  id          String       @id @default(uuid())
  question    String
  isAnonymous Boolean      @default(false)
  isActive    Boolean      @default(true)
  isArchived  Boolean      @default(false)
  options     PollOption[]
  votes       PollVote[]
  createdAt   DateTime     @default(now())
}

model PollOption {
  id      String     @id @default(uuid())
  pollId  String
  poll    Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text    String
  votes   PollVote[]
}

model PollVote {
  id        String     @id @default(uuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName  String
  createdAt DateTime   @default(now())

  @@unique([pollId, userId])
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  order     Int      @default(0)
}
